# RevOps Data Writer - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# META (FACEBOOK) ADS
# =============================================================================
# Get these from: https://developers.facebook.com/
META_ACCESS_TOKEN=your_meta_access_token_here
META_ACCOUNT_ID=act_123456789
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
# For Conversions API (optional)
META_PIXEL_ID=123456789
META_TEST_EVENT_CODE=TEST12345

# =============================================================================
# HUBSPOT
# =============================================================================
# Get these from: https://app.hubspot.com/
# Create a Private App in Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-token-here
HUBSPOT_PORTAL_ID=12345678

# =============================================================================
# STRIPE
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
# Use test mode keys (starting with sk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# SUPABASE
# =============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_public_key_here

# =============================================================================
# MIXPANEL
# =============================================================================
# Get these from: https://mixpanel.com/settings/project
MIXPANEL_PROJECT_TOKEN=your_mixpanel_project_token_here
MIXPANEL_API_SECRET=your_mixpanel_api_secret_here
# For service account (optional)
MIXPANEL_SERVICE_ACCOUNT_USERNAME=your_service_account_username
MIXPANEL_SERVICE_ACCOUNT_PASSWORD=your_service_account_password

# =============================================================================
# POSTHOG
# =============================================================================
# Get these from: https://app.posthog.com/project/settings
POSTHOG_API_KEY=phc_your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=12345

# =============================================================================
# FRESHDESK
# =============================================================================
# Get these from: https://yourcompany.freshdesk.com/a/admin/api_settings
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key_here

# =============================================================================
# DATABASE & GENERAL SETTINGS
# =============================================================================
# Local database path for storing extracted data
DB_PATH=revops_data.db

# Ingestion settings
BATCH_SIZE=100
LOOKBACK_DAYS=7
